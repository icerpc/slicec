module Slice::Compiler

struct DocComment {
    overview: Message
    \throws: Sequence<ThrowsTag>
    see: Sequence<SeeTag>
}

struct ThrowsTag {
    thrownType: SliceElementId
    message: Message
}

struct SeeTag {
    linkTo: SliceElementId
}

struct LinkTag {
    linkTo: SliceElementId
}

enum MessageComponent {
    Text(v: string)
    Link(v: LinkTag)
}

typealias Message = Sequence<MessageComponent>
