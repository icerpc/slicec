module SliceC

struct DocComment {
    overview: Message?,
    params: Sequence<ParamTag>,
    returns: Sequence<ReturnsTag>,
    \throws: Sequence<ThrowsTag>,
    see: Sequence<SeeTag>,
    span: Span,
}

struct ParamTag {
    identifier: Identifier,
    message: Message,
    span: Span,
}

struct ReturnsTag {
    identifier: Identifier?,
    message: Message,
    span: Span,
}

struct ThrowsTag {
    thrownType: AstPointer
    message: Message,
    span: Span,
}

struct SeeTag {
    linkTo: AstPointer
    span: Span,
}

struct LinkTag {
    linkTo: AstPointer
    span: Span,
}

enum MessageComponent {
    Text(v: string),
    Link(v: LinkTag),
}

struct Message {
    value: Sequence<MessageComponent>,
    span: Span,
}
